# Required
BUILDME_JWT_SECRET=change-me-to-a-random-32char-str
BUILDME_ENCRYPTION_KEY=change-me-32-bytes-exactly-here!

# Server
BUILDME_PORT=8080
BUILDME_BASE_URL=http://localhost:8080
BUILDME_DB_PATH=buildme.db
BUILDME_FRONTEND_DIST=frontend/dist

# GitHub OAuth (optional)
BUILDME_GITHUB_CLIENT_ID=
BUILDME_GITHUB_CLIENT_SECRET=

# Polling
BUILDME_POLL_INTERVAL_S=10
BUILDME_POLL_CONCURRENCY=5

# SMTP (optional, for email notifications)
BUILDME_SMTP_HOST=
BUILDME_SMTP_PORT=587
BUILDME_SMTP_USER=
BUILDME_SMTP_PASS=
BUILDME_SMTP_FROM=

# Web Push (optional)
BUILDME_VAPID_PUBLIC_KEY=
BUILDME_VAPID_PRIVATE_KEY=
